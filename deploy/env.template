# Terminus GIS — Environment Configuration
# Copy to lakehouse/.env and fill in values for your deployment.
#
# For local dev (Garage): just run ./bootstrap.sh — it generates .env automatically.
# For AWS S3: fill in the S3_* variables below.

# ─── S3 Storage ───────────────────────────────────────────────────────
# For AWS S3:
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=s3.us-east-1.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=terminus-lakehouse
S3_URL_STYLE=vhost
S3_USE_SSL=true
S3_PATH_STYLE=false
S3_FLAVOR=aws

# For local dev (Garage) — these are auto-generated by bootstrap.sh:
# GARAGE_KEY_ID=
# GARAGE_SECRET_KEY=
# GARAGE_ADMIN_TOKEN=
# S3_ENDPOINT=garage:3900
# S3_REGION=garage
# S3_URL_STYLE=path
# S3_USE_SSL=false
# S3_PATH_STYLE=true
# S3_FLAVOR=minio

# ─── LakeKeeper ──────────────────────────────────────────────────────
LAKEKEEPER_PG_ENCRYPTION_KEY=change-this-for-production

# ─── PyGeoAPI ─────────────────────────────────────────────────────────
# "auto" works for localhost, LAN, and EC2 (nginx rewrites URLs dynamically)
PYGEOAPI_SERVER_URL=auto

# ─── Spatial Agent (optional, --profile agent) ────────────────────────
SA_LLM_BACKEND=ollama
# SA_LLM_BACKEND=bedrock
# SA_BEDROCK_REGION=us-east-1
# SA_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514
# SA_PRIMARY_MODEL=devstral-small-2
# OLLAMA_MEM_LIMIT=16g

# ─── Webmap Basemaps ─────────────────────────────────────────────────
# BASEMAP_CONFIG=basemaps.json
# BASEMAP_CONFIG=basemaps-esri.json
# BASEMAP_CONFIG=basemaps-disconnected.json
