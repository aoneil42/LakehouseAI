# MCP connection
SA_MCP_ENDPOINT=http://mcp-server:8082/mcp

# Lakehouse API (for notify endpoint)
SA_LAKEHOUSE_API=http://lakehouse-api:8000

# LLM serving: 'vllm' or 'ollama'
SA_LLM_BACKEND=vllm
SA_VLLM_BASE_URL=http://localhost:8000/v1
SA_OLLAMA_BASE_URL=http://localhost:11434

# Model selection
SA_PRIMARY_MODEL=devstral-small-2
SA_MID_MODEL=ministral-3-14b-instruct
SA_FAST_MODEL=duckdb-nsql-7b
SA_ACTIVE_MODEL=

# Session
SA_SCRATCH_PREFIX=_scratch_
SA_MAX_RETRY=3
SA_QUERY_TIMEOUT=60

# Server
SA_HOST=0.0.0.0
SA_PORT=8090
